generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  wallet    String?  @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TriviaSession {
  id            String   @id @default(cuid())
  walletAddress String?
  learnerBand   String
  subject       String
  topic         String
  categoryTitle String
  questionsJson Json
  createdAt     DateTime @default(now())
}

model TriviaReward {
  id             String   @id @default(cuid())
  sessionId      String
  walletAddress  String
  correctAnswers Int
  totalQuestions Int
  rewardAmount   String
  categoryTitle  String
  claimedAt      DateTime @default(now())

  @@unique([sessionId, walletAddress])
}

model Subscription {
  id            String    @id @default(cuid())
  walletAddress String    @unique
  active        Boolean   @default(false)
  plan          String?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Word {
  id        String   @id @default(cuid())
  word      String
  hint      String
  level     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
